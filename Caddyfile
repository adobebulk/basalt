# ─── Caddyfile ────────────────────────────────────────────────────────────────
# Listens on :80 (localhost only — Cloudflare Tunnel handles public HTTPS).
#
# Routing:
#   photos.ctsmith.org/admin  → admin panel on :3001 (Cloudflare Access gates this)
#   photos.ctsmith.org/api/*  → admin panel on :3001 (API calls from admin UI)
#   photos.ctsmith.org/photos/* → admin panel on :3001 (photo preview in admin UI)
#   everything else           → Hugo static site in site/public/
#
# REPO_ROOT env var is set by the launchd plist (or export it manually for testing).

:80 {

  # ── Admin UI ──────────────────────────────────────────────────────────────
  # Redirect bare /admin to /admin/ so relative paths in the UI work correctly
  redir /admin /admin/ 308

  # Strip /admin prefix before proxying — admin panel sees / as its root
  handle_path /admin/* {
    reverse_proxy localhost:3001
  }

  # ── Admin API + photo preview (called root-relative by the admin UI JS) ───
  handle /api/* {
    reverse_proxy localhost:3001
  }
  handle /photos/* {
    reverse_proxy localhost:3001
  }

  # ── Public gallery ────────────────────────────────────────────────────────
  handle {
    root * {$REPO_ROOT}/site/public
    file_server

    # Clean URLs: /iceland → /iceland/index.html
    try_files {path} {path}/ {path}/index.html

    # Compression
    encode gzip

    # Cache images aggressively (Hugo fingerprints them)
    @images path *.jpg *.jpeg *.png *.webp *.avif *.gif *.ico *.svg
    header @images Cache-Control "public, max-age=31536000, immutable"

    # Shorter cache for HTML
    @html path *.html /
    header @html Cache-Control "public, max-age=300"
  }

}
