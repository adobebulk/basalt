{
  "name": "static-photos",
  "private": true,
  "scripts": {
    "css:build": "tailwindcss -i site/assets/css/input.css -o site/static/css/style.css --minify",
    "css:watch": "tailwindcss -i site/assets/css/input.css -o site/static/css/style.css --watch",
    "hugo:dev": "hugo server --source site --disableFastRender",
    "dev": "concurrently \"npm run css:watch\" \"npm run hugo:dev\"",
    "build": "npm run css:build && hugo --source site --minify",
    "admin": "node admin/server.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
